flowchart LR

%% =========================
%% AUTH FLOW
%% =========================
subgraph AUTH ["Authentication Flow"]
    A[Landing Screen] --> B{Is Auth?}
    B -->|No| C[Sign In / Sign Up]
    C --> D[Supabase Auth]
    B -->|Yes| E[Dashboard]
    D --> E
end

%% =========================
%% DASHBOARD MODULES
%% =========================
subgraph DASH ["Dashboard Modules"]
    E --> H[Home]
    E --> M[Models / Studio]
    E --> CAL[Calendar]
    E --> ACC[Accounts]
    E --> SET[Settings]
end

%% =========================
%% HOME → ANALYTICS
%% =========================
subgraph ANALYTICS ["Analytics Section"]
    H --> AN[Analytics Overview]
end

%% =========================
%% MODEL / STUDIO FLOW
%% =========================
subgraph MODEL ["AI Influencer Model"]
    M --> CM[Create New Model]
    
    CM --> CM1[Choose Gender]
    CM --> CM2[Select Age]
    CM --> CM3[Select Niche]
    CM --> CM4[Style & Tone]
    CM --> CM5[Upload Reference]
    
    CM5 --> GEN_MODEL[Generate AI Influencer]
end

%% =========================
%% POST CREATION FLOW
%% =========================
subgraph POST ["Post Creation Flow"]
    M --> P1[Create New Post]
    
    P1 --> P2[Select Model]
    P1 --> P3[Select Social Media Account]
    P1 --> P4[Enter Content Idea]
    P1 --> P5[Upload Reference Image]
    
    P2 --> GEN_POST[AI Post Generator]
    P3 --> GEN_POST
    P4 --> GEN_POST
    P5 --> GEN_POST
    
    GEN_POST --> PREVIEW[Post Preview UI]
end

%% =========================
%% SCHEDULER
%% =========================
subgraph SCHEDULER ["Auto Scheduler"]
    PREVIEW --> SCH[Schedule Post]
    SCH --> INST[Instagram]
    SCH --> LINK[LinkedIn]
    SCH --> TWIT[Twitter/X]
    SCH --> YT[YouTube]
end

%% =========================
%% TRACKING
%% =========================
subgraph TRACK ["Performance Tracking"]
    SCH --> PERF[Track Performance]
    
    PERF --> MET1[Engagement]
    PERF --> MET2[Reach]
    PERF --> MET3[Clicks]
end

%% =========================
%% PRICING SYSTEM
%% =========================
subgraph PRICING ["Pricing Model"]
    PR1[Free Plan\n300 Credits\n1 Account\nLimited Posts]
    PR2[Standard Plan\n2000 Credits\n5 Accounts\nUnlimited Posts]
    PR3[Pro Plan\n10000 Credits\nUnlimited Everything]
end

%% =========================
%% CREDIT SYSTEM
%% =========================
subgraph CREDIT ["Credit Usage"]
    GEN_MODEL -->|Uses Credits| CR1[50 Credits Deducted]
    GEN_POST -->|Uses Credits| CR2[20 Credits Deducted]
end

%% =========================
%% INTERACTIVITY (CLICKABLE)
