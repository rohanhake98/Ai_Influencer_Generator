click SET "https://yourapp.com/settings" "Settings"

%% =========================
%% STYLING
%% =========================
classDef primary fill:#1e293b,stroke:#38bdf8,color:#fff,stroke-width:2px
classDef secondary fill:#0f172a,stroke:#22c55e,color:#fff
classDef danger fill:#7f1d1d,stroke:#ef4444,color:#fff
classDef highlight fill:#1d4ed8,stroke:#93c5fd,color:#fff

class A,B,C,D,E primary
class H,M,CAL,ACC,SET secondary
class GEN_MODEL,GEN_POST highlight
class SCH,PERF highlight
class PR1,PR2,PR3 secondary
class CR1,CR2 danger